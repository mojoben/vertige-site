# Payload + Postgres (dev shares the res-platform Supabase in the isolated
# "site" schema — see payload.config.ts)
DATABASE_URL=postgresql://user:pass@host:5432/postgres
PAYLOAD_SECRET=change-me

# Res-portal connection (HANDOFF 03 §2): the site READS properties/availability
# from the portal and WRITES enquiries to it. Key = portal Settings → Config.
PORTAL_URL=http://localhost:3000
PORTAL_API_KEY=

# Doc 10 shared-DB read path: the site reads portal data live through the
# web.* views. At deploy set this to the site's read-only DB user (role
# vertige_web). Falls back to DATABASE_URL in dev (same shared Postgres).
# WEB_DATABASE_URL=postgres://site_user:...@private-host/db
